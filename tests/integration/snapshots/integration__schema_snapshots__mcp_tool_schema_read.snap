      "id": {
        "description": "The memory ID to retrieve.",
        "$ref": "#/$defs/MemoryId"
      }
    },
    "required": [
      "id"
    ],
    "$defs": {
      "MemoryId": {
        "description": "A ULID-formatted unique memory identifier",
        "type": "string"
      }
    }
  }
}
