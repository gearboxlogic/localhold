---
source: tests/integration/schema_snapshots.rs
expression: tool
---
{
  "name": "read_many",
  "description": "Read multiple full memories by id. Preserves input order, returns per-item not_found for missing/unreadable IDs, caps at max_batch_size, and records one read activity event for found IDs only for trusted principals.",
  "inputSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "ReadManyParams",
    "description": "Parameters for the v2 `read_many` tool.",
    "type": "object",
    "properties": {
      "ids": {
        "description": "Memory IDs to retrieve. Order is preserved; missing or unreadable IDs return per-item `not_found`; batch size is capped by `limits.max_batch_size`.",
        "type": "array",
        "items": {
          "$ref": "#/$defs/MemoryId"
        }
      }
    },
    "required": [
      "ids"
    ],
    "$defs": {
      "MemoryId": {
        "description": "A ULID-formatted unique memory identifier",
        "type": "string"
      }
    }
  }
}
